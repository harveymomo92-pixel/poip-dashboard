# Production template. Copy to .env.production on the server and fill values
# from a password manager or secret store. Never commit real values.
NODE_ENV=production
APP_TIMEZONE=Asia/Jakarta
APP_VERSION=replace-with-release-version

API_PORT=4000
WEB_ORIGIN=https://ppic.example.local
NEXT_PUBLIC_API_BASE_URL=https://ppic.example.local/api/v1
API_BASE_URL=https://ppic.example.local/api/v1

# Use service names when API/worker run on the same Docker network.
DATABASE_URL=postgres://ppic_app:replace-with-database-password@postgres:5432/ppic_output_intelligence
REDIS_URL=redis://redis:6379

# Generate independent high-entropy values.
SESSION_SECRET=replace-with-64-plus-random-characters
AUTH_SECRET=replace-with-64-plus-random-characters

# Bootstrap only. Remove or rotate after creating the first real admin.
ADMIN_EMAIL=admin@example.local
ADMIN_NAME=System Admin
ADMIN_PASSWORD=replace-with-temporary-bootstrap-password

# Business Central / OData.
ODATA_SYNC_MODE=live
ODATA_SYNC_CONCURRENCY=1
BC_ODATA_URL=http://tailscale-or-lan-host.example.local:7048/BC/ODataV4/Company('COMPANY')/ProductionOutput
BC_ODATA_AUTH_MODE=basic
BC_ODATA_USERNAME=replace-with-odata-username
BC_ODATA_PASSWORD=replace-with-odata-password
BC_ODATA_BASE_URL=
BC_ODATA_OUTPUT_ENDPOINT=
BC_ODATA_BEARER_TOKEN=
BC_ODATA_PAGE_SIZE=1000
BC_ODATA_TIMEOUT_MS=30000

# One-time live OData backfill controls. Set per run; do not store real secrets here.
BACKFILL_FROM=2026-01-01
BACKFILL_TO=
BACKFILL_DATE_FIELD=Posting_Date
BACKFILL_PAGE_SIZE=
BACKFILL_MAX_PAGES=
