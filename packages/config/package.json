{
  "name": "@poip/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./tsconfig/base": "./tsconfig/base.json",
    "./tsconfig/next": "./tsconfig/next.json",
    "./tsconfig/node": "./tsconfig/node.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . && node ../../scripts/check-no-latest.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test src/*.test.mjs",
    "check:deps": "node ../../scripts/check-no-latest.mjs"
  },
  "devDependencies": {
    "@types/node": "24.0.3",
    "typescript": "5.8.3"
  }
}
