# Local development defaults. Copy to .env for local work only.
# Production values must be supplied by the deployment environment or a protected
# .env.production file that is never committed.
NODE_ENV=development
APP_TIMEZONE=Asia/Jakarta
APP_VERSION=local

WEB_PORT=3000
API_PORT=4000
API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
WEB_ORIGIN=http://localhost:3000

# Host-local Docker Compose database. If the API/worker run inside a container,
# use postgres and redis service names instead of localhost.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ppic_output_intelligence
POSTGRES_USER=ppic_app
POSTGRES_PASSWORD=change-me-local
DATABASE_URL=postgres://ppic_app:change-me-local@localhost:5432/ppic_output_intelligence

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Replace both secrets before any shared/staging/production deployment.
SESSION_SECRET=replace-with-a-secure-random-value
AUTH_SECRET=replace-with-a-secure-random-value

# Local bootstrap admin only. Do not reuse these values in production.
ADMIN_EMAIL=admin@example.local
ADMIN_NAME=System Admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Business Central / OData. Leave ODATA_SYNC_MODE=mock for local development.
BC_ODATA_URL=
BC_ODATA_BASE_URL=
BC_ODATA_OUTPUT_ENDPOINT=
BC_ODATA_AUTH_MODE=none
BC_ODATA_USERNAME=
BC_ODATA_PASSWORD=
BC_ODATA_TENANT=
BC_ODATA_CLIENT_ID=
BC_ODATA_CLIENT_SECRET=
BC_ODATA_BEARER_TOKEN=
BC_ODATA_PAGE_SIZE=1000
BC_ODATA_TIMEOUT_MS=30000
BC_ODATA_RETRY_ATTEMPTS=2
ODATA_SYNC_MODE=mock
ODATA_SYNC_CONCURRENCY=1

# One-time live OData backfill controls. Use only with ODATA_SYNC_MODE=live.
BACKFILL_FROM=2026-01-01
BACKFILL_TO=
BACKFILL_DATE_FIELD=Posting_Date
BACKFILL_AFTER_ENTRY_NO=
BACKFILL_PAGE_SIZE=
BACKFILL_MAX_PAGES=
BACKFILL_CHECK_TOP=
BACKFILL_CHECK_MAX_PAGES=
BACKFILL_CHUNK_PAGES=
BACKFILL_MAX_CHUNKS=
BACKFILL_CHUNK_RETRIES=
