{
  "name": "@poip/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . && node ../../scripts/check-no-latest.mjs",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && node --test dist/**/*.test.js",
    "check:deps": "node ../../scripts/check-no-latest.mjs"
  },
  "dependencies": {
    "@poip/domain": "workspace:0.1.0",
    "bullmq": "5.56.0",
    "ioredis": "5.6.1"
  },
  "devDependencies": {
    "@types/node": "24.0.3",
    "tsx": "4.20.3",
    "typescript": "5.8.3"
  }
}
